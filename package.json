{
    "name": "@plurnk/plurnk-mimetypes-application-pdf",
    "version": "0.6.3",
    "description": "application/pdf mimetype handler for plurnk-service. Binary content; hybrid preview surfaces bookmark outline/Title when present and falls back to extracted page text otherwise; query supports regex/glob via extracted text and jsonpath against the outline.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=25"
    },
    "plurnk": {
        "kind": "mimetype",
        "binary": true,
        "handlers": [
            {
                "name": "application/pdf",
                "glyph": "📕",
                "extensions": [
                    ".pdf"
                ]
            }
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build"
    },
    "dependencies": {
        "pdfjs-dist": "^6.0.227"
    },
    "devDependencies": {
        "@types/node": "^25.8.0",
        "typescript": "^6.0.3",
        "@plurnk/plurnk-mimetypes": "^0.15.0"
    },
    "peerDependencies": {
        "@plurnk/plurnk-mimetypes": "^0.15.0"
    }
}
