# @plurnk/plurnk-mimetypes-application-pdf — configuration knobs.
# Both caps are OPTIONAL and UNBOUNDED by default (the handler invents no budget
# it can't validate as your intent). Set either to a positive integer to cap;
# unset → no cap; malformed (non-positive-integer) → crash, never a silent
# fallback. Read at call time.

# PLURNK_PDF_MAX_BYTES — reject a PDF larger than this many bytes before it
# reaches the parser (decompression-bomb resistance). Unset → no byte cap.
# Example: PLURNK_PDF_MAX_BYTES=104857600
PLURNK_PDF_MAX_BYTES=

# PLURNK_PDF_MAX_PAGES — stop text/symbol/link extraction after this many pages
# (pathological-page-count resistance). Unset → read every page.
# Example: PLURNK_PDF_MAX_PAGES=5000
PLURNK_PDF_MAX_PAGES=
